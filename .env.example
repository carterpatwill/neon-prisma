# Neon Postgres connection string.
#
# Get this from the Neon Console (Dashboard -> Connect) or the Neon CLI:
#   neon connection-string           # current branch
#   neon connection-string <branch>  # a specific branch
#
# Each Neon branch has its own connection string — swap this value to point
# the app at a different branch.
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require"
