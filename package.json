{
  "name": "neon-prisma-rockies",
  "version": "1.0.0",
  "description": "A demo of Neon Postgres database branching and Prisma migrations, using a Colorado Rockies roster as sample data.",
  "type": "commonjs",
  "scripts": {
    "seed": "tsx --env-file=.env seed.ts",
    "seed:salary-age": "tsx --env-file=.env seed-salary-age.ts",
    "view": "tsx --env-file=.env view.ts",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:migrate": "prisma migrate deploy"
  },
  "keywords": [
    "neon",
    "postgres",
    "prisma",
    "database-branching",
    "migrations",
    "demo"
  ],
  "author": "carterpatwill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carterpatwill/neon-prisma.git"
  },
  "bugs": {
    "url": "https://github.com/carterpatwill/neon-prisma/issues"
  },
  "homepage": "https://github.com/carterpatwill/neon-prisma#readme",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0"
  }
}
